modules = ["go", "go-1.21"]

[nix]
channel = "stable-24_05"
packages = ["hugo"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Hugo Server"

[[workflows.workflow]]
name = "Hugo Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "hugo server -D --bind=0.0.0.0 -p 5000"
waitForPort = 5000

[deployment]
run = ["sh", "-c", "hugo server -D --bind=0.0.0.0 -p 5000"]

[[ports]]
localPort = 5000
externalPort = 80
